{
  "name": "next-blog",
  "version": "0.1.0",
  "description": "Next.js blog base for building the next reusable, next-level blog project.",
  "author": "Caio Frota <caiofrota@gmail.com>",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "admin:create": "tsx scripts/create-admin-user.ts",
    "wp:migrate": "tsx scripts/migrate-wordpress.ts",
    "update:instagram-feed": "tsx scripts/update-instagram-feed.ts blog",
    "media:rename-prefix": "tsx scripts/rename-media-prefix.ts",
    "proxy:add": "PROXY_PORTS='3000' sh ./scripts/proxy-add.sh",
    "proxy:remove": "PROXY_PORTS='3000' sh ./scripts/proxy-remove.sh",
    "proxy:list": "powershell.exe -Command \"netsh interface portproxy show all\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.583.0",
    "@prisma/client": "^5.14.0",
    "@tiptap/extension-image": "^2.4.0",
    "@tiptap/extension-link": "^2.4.0",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "@types/nodemailer": "^8.0.0",
    "clsx": "^2.1.1",
    "next": "^14.2.3",
    "nodemailer": "^8.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
